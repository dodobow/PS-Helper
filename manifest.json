{
    "manifest_version" : 3,
    "name" : "Algosaurus (알고사우루스)",
    "version" : "0.9.0",
    "description" : "Solved.ac 데이터를 기반으로 PS 학습을 도와주는 확장 프로그램",
    "action" : {
        "default_popup" : "popup/popup.html",
        "default_title" : "알고사우루스 열기"
    },
    "host_permissions" : [
        "https://solved.ac/*"
    ],
    "permissions" : [
        "storage"
    ],
    "options_ui" : {
        "page" : "options/options.html",
        "open_in_tab" : true
    }
}